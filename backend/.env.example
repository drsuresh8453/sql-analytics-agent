# Author: Suresh D R | AI Product Developer & Technology Mentor
# Copy this to .env and fill in your real values. Never commit .env.

# ── OpenAI ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here

# ── AWS ─────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=eu-north-1

# ── RDS PostgreSQL (MUST be the read-only user, not admin) ──────────────
RDS_HOST=your-rds-endpoint.rds.amazonaws.com
RDS_PORT=5432
RDS_DB=supportagent
RDS_USER=sql_agent_readonly
RDS_PASSWORD=your-readonly-user-password

# ── Redis ────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
CACHE_ENABLED=true
CACHE_TTL_QUERY_SECONDS=600
CACHE_TTL_SCHEMA_SECONDS=3600

# ── LangSmith tracing (set to true + add key to enable) ─────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your-langsmith-key-here
LANGCHAIN_PROJECT=sql-analytics-agent

# ── Rate limiting ────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=30
INVESTIGATIVE_CALL_LIMIT_PER_SESSION=30
INVESTIGATIVE_CALL_WINDOW_SECONDS=300

# ── App ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
